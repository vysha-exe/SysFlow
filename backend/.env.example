PORT=4000

# Required — no angle brackets around username or password.
# Database **sysflow** is used by default (see mongoose dbName in code). Optional: /sysflow in the URI.
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/sysflow?retryWrites=true&w=majority
# Optional: MONGODB_DB_NAME=other_db

# Optional: comma-separated origins for browser clients (e.g. https://your-app.vercel.app)
# CORS_ORIGIN=
