# The app uses database **sysflow** by default (Mongoose `dbName`). Override with MONGODB_DB_NAME if needed.
# You can still put /sysflow in the URI for clarity; dbName wins when both are set.
MONGODB_URI=
# MONGODB_DB_NAME=sysflow
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
DEV_BYPASS_AUTH=false

# --- Optional: anchor journal entry hashes on Solana (server-funded memo txs) ---
# Generate a throwaway keypair (e.g. solana-keygen new) and base64 the 64-byte secret:
#   node -e "console.log(require('fs').readFileSync(process.env.HOME+'/.config/solana/id.json'))"  # or paste JSON array
# For devnet, fund the public address with `solana airdrop 1 <addr> --url devnet`
# SOLANA_CLUSTER=devnet
# SOLANA_RPC_URL=
# SOLANA_ANCHOR_SECRET_KEY=
