# The app uses database **sysflow** by default (Mongoose `dbName`). Override with MONGODB_DB_NAME if needed.
# You can still put /sysflow in the URI for clarity; dbName wins when both are set.
MONGODB_URI=
# MONGODB_DB_NAME=sysflow
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEV_BYPASS_AUTH=false
